{
  "uid": "f7ace415-6dd3-495d-8a22-43e37d2fbae4",
  "title": "ACM API",
  "tags": ["acm"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Prometheus",
        "pluginId": "prometheus",
        "query": "prometheus",
        "refresh": 1,
        "hide": 2,
        "current": { "text": "Prometheus", "value": "prometheus" }
      },
      {
        "name": "environment",
        "type": "query",
        "label": "Omgeving",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\"}, deployment_environment)",
        "query": {
          "qryType": 1,
          "query": "label_values(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\"}, deployment_environment)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 1,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "hide": 0,
        "options": [],
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "SLO: Responstijd < 600ms",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Trage requests (>600ms)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 6 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"+Inf\"}[$__rate_interval])) - sum(increase(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"0.6\"}[$__rate_interval]))",
          "legendFormat": "trage requests",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "noValue": "0"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "% requests > 600ms",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 6 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 * (sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"+Inf\"}[$__rate_interval])) - sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"0.6\"}[$__rate_interval]))) / sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"+Inf\"}[$__rate_interval]))",
          "legendFormat": "% traag",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "noValue": "0%",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["mean"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "noValue": "0%"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Trage requests over tijd (>600ms)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 6 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (http_route, http_request_method) (rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"+Inf\"}[$__rate_interval])) - sum by (http_route, http_request_method) (rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"0.6\"}[$__rate_interval]))",
          "legendFormat": "{{http_request_method}} {{http_route}}",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 3,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "sum"] }
      }
    },
    {
      "id": 5,
      "type": "row",
      "title": "Latency per endpoint",
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "p99 Latency per endpoint (drempel: 600ms)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 10 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\"}[$__rate_interval])) by (le, http_route, http_request_method))",
          "legendFormat": "p99 {{http_request_method}} {{http_route}}",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.4 },
              { "color": "red", "value": 0.6 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "p95 Latency per endpoint",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 9 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\"}[$__rate_interval])) by (le, http_route, http_request_method))",
          "legendFormat": "p95 {{http_request_method}} {{http_route}}",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "p50 Latency per endpoint",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 9 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\"}[$__rate_interval])) by (le, http_route, http_request_method))",
          "legendFormat": "p50 {{http_request_method}} {{http_route}}",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    }
  ]
}
