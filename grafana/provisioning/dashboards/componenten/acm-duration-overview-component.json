{
  "id": null,
  "uid": "acm-duration-overview-component",
  "title": "[COMPONENT] ACM duration overview",
  "tags": ["acm", "component"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Prometheus",
        "pluginId": "prometheus",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
        "current": { "text": "Prometheus", "value": "prometheus" }
      },
      {
        "name": "environment",
        "type": "query",
        "label": "Omgeving",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(target_info, deployment_environment)",
        "query": { "qryType": 1, "query": "label_values(target_info, deployment_environment)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 1,
        "sort": 1,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "p50 Latency per endpoint",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 9 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\"}[$__rate_interval])) by (le, http_route, http_request_method))",
          "legendFormat": "p50 {{http_request_method}} {{http_route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p95 Latency per endpoint",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 9 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\"}[$__rate_interval])) by (le, http_route, http_request_method))",
          "legendFormat": "p95 {{http_request_method}} {{http_route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.4 },
              { "color": "red", "value": 0.6 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p99 Latency per endpoint",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 9 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\"}[$__rate_interval])) by (le, http_route, http_request_method))",
          "legendFormat": "p99 {{http_request_method}} {{http_route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.4 },
              { "color": "red", "value": 0.6 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    }
  ]
}

