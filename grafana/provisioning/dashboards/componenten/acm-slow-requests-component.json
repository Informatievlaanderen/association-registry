{
  "id": null,
  "uid": "acm-slow-requests-component",
  "title": "[COMPONENT] ACM trage requests (>600ms)",
  "tags": ["acm", "component"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Prometheus",
        "pluginId": "prometheus",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
        "current": { "text": "Prometheus", "value": "prometheus" }
      },
      {
        "name": "environment",
        "type": "query",
        "label": "Omgeving",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(target_info, deployment_environment)",
        "query": { "qryType": 1, "query": "label_values(target_info, deployment_environment)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 1,
        "sort": 1,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Trage requests (>600ms)",
      "description": "Totaal aantal requests dat langer dan 600ms duurde in het geselecteerde tijdvenster",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"+Inf\"}[$__rate_interval])) - sum(increase(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"0.6\"}[$__rate_interval]))",
          "instant": false,
          "range": true,
          "legendFormat": "trage requests"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "noValue": "0"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "% requests > 600ms",
      "description": "Percentage trage requests (>600ms) in het geselecteerde tijdvenster",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 * (sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"+Inf\"}[$__rate_interval])) - sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"0.6\"}[$__rate_interval]))) / sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"+Inf\"}[$__rate_interval]))",
          "instant": false,
          "range": true,
          "legendFormat": "% traag"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "noValue": "0%",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["mean"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "noValue": "0%"
      }
    },
    {
      "id": 4,
      "type": "bargauge",
      "title": "Responsetijd verdeling (tijdvenster)",
      "description": "Percentage requests per latency bucket over het geselecteerde tijdvenster",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"0.1\"}[$__rate_interval])) / sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"+Inf\"}[$__rate_interval])) * 100",
          "legendFormat": "≤ 100ms",
          "instant": false,
          "range": true
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"0.25\"}[$__rate_interval])) - sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"0.1\"}[$__rate_interval]))) / sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"+Inf\"}[$__rate_interval])) * 100",
          "legendFormat": "100ms – 250ms",
          "instant": false,
          "range": true
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"0.6\"}[$__rate_interval])) - sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"0.25\"}[$__rate_interval]))) / sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"+Inf\"}[$__rate_interval])) * 100",
          "legendFormat": "250ms – 600ms",
          "instant": false,
          "range": true
        },
        {
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"0.75\"}[$__rate_interval])) - sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"0.6\"}[$__rate_interval]))) / sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"+Inf\"}[$__rate_interval])) * 100",
          "legendFormat": "600ms – 750ms",
          "instant": false,
          "range": true
        },
        {
          "refId": "E",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"+Inf\"}[$__rate_interval])) - sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"0.75\"}[$__rate_interval]))) / sum(rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"+Inf\"}[$__rate_interval])) * 100",
          "legendFormat": "> 750ms",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "≤ 100ms" },       "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "100ms – 250ms" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "light-green" } }] },
          { "matcher": { "id": "byName", "options": "250ms – 600ms" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "600ms – 750ms" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "> 750ms" },       "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["mean"] },
        "text": {}
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Trage requests over tijd (>600ms)",
      "description": "Aantal requests dat langer dan 600ms duurde per tijdseenheid",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 9 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (http_route, http_request_method) (rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"+Inf\"}[$__rate_interval])) - sum by (http_route, http_request_method) (rate(http_server_request_duration_seconds_bucket{job=~\"(?i).*acm.*\", le=\"0.6\"}[$__rate_interval]))",
          "legendFormat": "{{http_request_method}} {{http_route}}",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 3,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "sum"] }
      }
    }
  ]
}
