{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
   "extends": [
     "config:base"
  ],
  "packageRules": [
    { "matchManagers": ["nuget"], "semanticCommitType": "fix" },
    { "matchUpdateTypes": ["patch"], "automerge": true, "autoApprove": true }
  ],
  "platformAutomerge": true
}
